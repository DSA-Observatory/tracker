# PocketBase Configuration
POCKETBASE_PORT=46218

# Frontend Configuration
FRONTEND_PORT=46217
PUBLIC_APP_URL=http://localhost:46217

# Public PocketBase URL (used by frontend in browser)
PUBLIC_POCKETBASE_URL=http://localhost:46218

# Server-side PocketBase URL (internal Docker network, for server-side requests)
POCKETBASE_URL=http://pocketbase:8090

# Development
NODE_ENV=development


# PocketBase Admin Credentials (for initial setup and data import)
POCKETBASE_ADMIN_EMAIL=admin@admin.local
POCKETBASE_ADMIN_PASSWORD=1234567890


# SMTP Configuration for sending emails
# Set SMTP_ENABLED=true to enable email sending
SMTP_ENABLED=false
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_smtp_password_here
SMTP_FROM=Your App Name <noreply@yourdomain.com>

# Comma-separated recipients for new suggested case notifications
CASE_SUBMISSION_NOTIFY_EMAILS=

# Broken link checker cron, run by PocketBase pb_hooks
LINK_CHECK_ENABLED=true
LINK_CHECK_CRON="0 3 * * *"
LINK_CHECK_TIMEOUT_SECONDS=15
